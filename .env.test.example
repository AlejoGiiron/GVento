# ── Credenciales para los tests E2E (Playwright) ──
# Copia este archivo a .env.test y completa con las cuentas de prueba.
# .env.test está en .gitignore — NUNCA commitear credenciales.
#
# Las cuentas pertenecen a la organización de LABORATORIO ("LAB"), aislada de
# los datos reales (org "G-10"). Las crea/reconcilia supabase/lab-seed.sql:
#   - owner.test@gvento.com   rol "owner"  (todos los permisos)
#   - cajero.test@gvento.com  rol "cajero" (sin Productos / Reportes / Config)
#   - mozo.test@gvento.com    rol "mozo"   (OPCIONAL — rol restringido para probar
#                             gating negativo; sin caja.*, fiado, historiales…)
# El health check de tests/global-setup.ts ABORTA si la org no es "LAB".
# Ver tests/README.md → "Laboratorio".

E2E_OWNER_EMAIL=owner.test@gvento.com
E2E_OWNER_PASSWORD=cambia-esto

E2E_CASHIER_EMAIL=cajero.test@gvento.com
E2E_CASHIER_PASSWORD=cambia-esto

# Opcional (gating negativo). Si no se define, los tests que usan el mozo hacen
# skip. Para habilitarlo: crear la cuenta mozo.test@gvento.com en Auth (Supabase),
# re-correr lab-seed.sql (auto-descubre su UID y crea profile+user_stores) y
# definir estas dos variables.
E2E_WAITER_EMAIL=mozo.test@gvento.com
E2E_WAITER_PASSWORD=cambia-esto

# Opcional: URL base si el dev server no corre en el puerto por defecto.
# E2E_BASE_URL=http://localhost:5173
